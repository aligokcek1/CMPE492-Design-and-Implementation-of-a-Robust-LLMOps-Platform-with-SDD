{
  "uid": "deployment-metrics-template",
  "title": "LLMOps Deployment Metrics",
  "tags": ["llmops", "deployment"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "TTFT (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(llmops_ttft_seconds_bucket{deployment_id=\"$deployment_id\", user_id=\"$user_id\"}[5m])) by (le))",
          "legendFormat": "p95 TTFT"
        }
      ]
    },
    {
      "id": 2,
      "title": "Throughput (tokens/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(llmops_tokens_total{deployment_id=\"$deployment_id\", user_id=\"$user_id\"}[5m]))",
          "legendFormat": "tokens/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "CPU Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{deployment_id=\"$deployment_id\", user_id=\"$user_id\"}[5m])",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "id": 4,
      "title": "Memory (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{deployment_id=\"$deployment_id\", user_id=\"$user_id\"}",
          "legendFormat": "RSS"
        }
      ]
    },
    {
      "id": 5,
      "title": "GPU Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "gpu_utilization{deployment_id=\"$deployment_id\", user_id=\"$user_id\"}",
          "legendFormat": "GPU"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "deployment_id",
        "type": "textbox",
        "hide": 2
      },
      {
        "name": "user_id",
        "type": "textbox",
        "hide": 2
      }
    ]
  }
}
